# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-nano
OPENAI_THINKING_EFFORT=minimal
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Qdrant ───────────────────────────────────────────────
QDRANT_URL=https://...qdrant.io
QDRANT_API_KEY=...
QDRANT_COLLECTION_NAME=ssas_qa_cache

# ─── Langfuse ─────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── SSAS (only needed when USE_MOCK_CUBE=false) ──────────
SSAS_URL=http://your-ssas-host:port/olap/msmdpump.dll
SSAS_API_KEY=

# ─── Pipeline Settings ────────────────────────────────────
# Number of questions to generate per batch
QUESTIONS_PER_BATCH=20
# Total target number of questions
TARGET_QUESTION_COUNT=200
# Language for generated questions (tr / en / both)
QUESTION_LANGUAGE=tr

# ─── Development Settings ─────────────────────────────────
# true = use mock cube data instead of real SSAS connection
USE_MOCK_CUBE=true
