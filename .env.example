# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_THINKING_EFFORT=minimal
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=https://your-cluster.aws.cloud.qdrant.io
QDRANT_PORT=6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=ssas_qa_cache

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=ssas_postgres
POSTGRES_PORT=5432
POSTGRES_DB=ssas_cache
POSTGRES_USER=ssas
POSTGRES_PASSWORD=ssas

# ─── Langfuse (optional — remove if not using) ────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── SSAS Bridge ──────────────────────────────────────────────────────────────
SSAS_URL=https://your-ssas-bridge.example.com
SSAS_API_KEY=your-ssas-api-key

# ─── Pipeline ─────────────────────────────────────────────────────────────────
USE_MOCK_CUBE=false
QUESTIONS_PER_CUBE=50
QUESTIONS_PER_BATCH=20
QUESTION_LANGUAGE=en
ENABLE_MDX_GENERATION=true

# ─── Cache ────────────────────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.75
SIMILARITY_PARAPHRASE_THRESHOLD=0.95
